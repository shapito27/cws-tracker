{
  "manifest_version": 3,
  "name": "CWS Tracker",
  "description": "ASO and competitive intelligence for Chrome Web Store. Track keyword rankings, monitor competitor listings, and optimize your extension.",
  "version": "0.12.0",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "src/assets/icon-16.png",
      "48": "src/assets/icon-48.png",
      "128": "src/assets/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://chromewebstore.google.com/*"
  ],
  "icons": {
    "16": "src/assets/icon-16.png",
    "48": "src/assets/icon-48.png",
    "128": "src/assets/icon-128.png"
  }
}
